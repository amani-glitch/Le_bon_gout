# Production build config (baked into the bundle by `vite build`).
# Frontend and backend are served from the same Cloud Run service, so the
# API is reached at a same-origin relative path.
VITE_API_URL=/api
# Public Stripe publishable key (safe to ship to the browser). Replace with
# your real pk_live_/pk_test_ key to enable online payments in production.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
